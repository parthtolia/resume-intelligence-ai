{
    "routes": [
        {
            "route": "/.auth/login/aad",
            "allowedRoles": [
                "anonymous",
                "authenticated"
            ]
        },
        {
            "route": "/.auth/logout",
            "allowedRoles": [
                "anonymous",
                "authenticated"
            ]
        },
        {
            "route": "/.auth/me",
            "allowedRoles": [
                "anonymous",
                "authenticated"
            ]
        },
        {
            "route": "/*",
            "allowedRoles": [
                "authenticated"
            ]
        }
    ],
    "responseOverrides": {
        "401": {
            "redirect": "/.auth/login/aad?post_login_redirect_uri=/",
            "statusCode": 302
        }
    },
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/*.{png,jpg,jpeg,gif,css,js}"
        ]
    }
}